<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:background="@color/verde_principal"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="10dp"
            android:paddingEnd="22dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegresar"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text=""
                app:icon="@drawable/ic_arrow_back_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="34dp"
                app:iconTint="@color/texto_claro"
                app:cornerRadius="28dp"
                app:rippleColor="@color/verde_oscuro" />

            <TextView
                android:id="@+id/tvTituloFormulario"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="Nuevo potrero"
                android:textColor="@color/texto_claro"
                android:textSize="30sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:background="@drawable/edittext_borde"
                android:hint="Nombre del lote"
                android:inputType="textCapWords"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/texto_oscuro"
                android:textSize="22sp" />

            <EditText
                android:id="@+id/etMetros"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/edittext_borde"
                android:hint="Medidas (m²)"
                android:inputType="numberDecimal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/texto_oscuro"
                android:textSize="22sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFecha"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:text="Fecha de creación"
                android:textColor="@color/verde_principal"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                app:strokeColor="@color/texto_oscuro"
                app:strokeWidth="1dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="250dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSeleccionarFoto"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Seleccionar foto"
                android:textColor="@color/texto_oscuro"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/morado_suave"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSeleccionarVideo"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:text="Seleccionar video"
                android:textColor="@color/texto_oscuro"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/morado_suave"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="38dp"
                android:text="Guardar"
                android:textColor="@color/texto_claro"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/verde_principal"
                app:cornerRadius="28dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>